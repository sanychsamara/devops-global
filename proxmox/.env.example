# ── Proxmox DevOps VM Factory configuration ───────────────────────────────
# Copy to `.env` and fill in.  `.env` is gitignored — keep secrets out of git.

# --- Proxmox API ---------------------------------------------------------
# Always use the Tailscale name (or IP). Never the local 192.168.1.21.
PVE_HOST=proxmox.flamingo-banjo.ts.net
# PVE_HOST=100.104.12.124          # alternative: Tailscale IP
PVE_PORT=8006
PVE_NODE=proxmox
PVE_VERIFY_TLS=false               # self-signed cert; set true only if you pin the CA

# API token (PREFERRED — create with setup/00-create-api-token.md).
# Format of PVE_TOKEN_ID is  USER@REALM!TOKENNAME
PVE_TOKEN_ID=root@pam!devops
PVE_TOKEN_SECRET=

# Fallback only (discouraged): username/password auth if no token is set.
# PVE_USER=root@pam
# PVE_PASSWORD=

# --- Defaults for new VMs ------------------------------------------------
PROXMOX_DEVOPS_TEMPLATE_ID=9000    # golden Ubuntu template built by setup/10-build-template.sh
PROXMOX_DEVOPS_STORAGE=local-lvm   # where VM disks live (snapshot-capable LVM-thin)
PROXMOX_DEVOPS_CPU=host            # 'host' exposes AVX/AVX2 (needed by NumPy/OpenBLAS); single node => migration portability is moot
PROXMOX_DEVOPS_BRIDGE=vmbr0
PROXMOX_DEVOPS_CIUSER=ubuntu
# Public SSH key injected into every VM (path on THIS machine):
PROXMOX_DEVOPS_SSH_PUBKEY=C:\Users\alex\.ssh\id_ed25519.pub

# --- Backups -------------------------------------------------------------
PROXMOX_DEVOPS_BACKUP_STORAGE=NAS1            # NFS, 8.6 TB
PROXMOX_DEVOPS_BACKUP_SCHEDULE=sun 03:00      # systemd calendar event (weekly, Sunday 3am)
PROXMOX_DEVOPS_BACKUP_RETENTION=keep-weekly=4

# --- Tailscale -----------------------------------------------------------
# Reusable, pre-approved, tagged auth key (Mode A, zero-touch join).
# Generate at https://login.tailscale.com/admin/settings/keys
# Used by setup/20-enable-snippets.sh when generating the vendor snippet.
TS_AUTHKEY=

# --- Monitoring: Synology SNMPv3 (SHA, authNoPriv) — see monitoring/README.md ---
MON_SNMP_USER=
MON_SNMP_AUTH=
MON_SNMP_HOSTS=homenas=100.85.234.68     # comma-separated name=ip pairs

# Generic SSH-reachable Linux hosts (name=user@host, comma-separated).
# Needs non-interactive SSH from the monitor VM (e.g. a Tailscale ACL 'accept' rule, no check).
MON_SSH_HOSTS=manus-sandbox=root@manus-sandbox.flamingo-banjo.ts.net

# Telegram delivery of the report (Bot API token from BotFather + chat id)
MON_TELEGRAM_TOKEN=
MON_TELEGRAM_CHAT=                        # e.g. -5237632917 (group chat id)

# Weekly LLM right-sizing analysis (analyze.py) — Anthropic models via OpenRouter.
# OPENROUTER_API_KEY is read from the environment if set; otherwise put it here.
OPENROUTER_API_KEY=
MON_LLM_MODEL=anthropic/claude-haiku-4.5  # OpenRouter slug; cheap default
